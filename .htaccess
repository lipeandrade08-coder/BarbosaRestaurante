# ── HTTPS redirect (só em produção, não afeta localhost) ────────────────────
RewriteEngine On
RewriteCond %{HTTPS} off
RewriteCond %{HTTP_HOST} !^localhost [NC]
RewriteCond %{HTTP_HOST} !^127\.0\.0\.1
RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

# ── Segurança: Headers HTTP ──────────────────────────────────────────────────
<IfModule mod_headers.c>
  Header always set X-Frame-Options "SAMEORIGIN"
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  Header always set Permissions-Policy "geolocation=(), camera=(), microphone=()"
</IfModule>

# ── Compressão Gzip ──────────────────────────────────────────────────────────
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/css application/javascript text/plain text/xml application/json
</IfModule>

# ── Cache de assets estáticos ────────────────────────────────────────────────
<IfModule mod_headers.c>
  <FilesMatch "\.(woff2|woff|ttf)$">
    Header set Cache-Control "max-age=31536000, immutable"
  </FilesMatch>
  <FilesMatch "\.(png|jpg|jpeg|gif|webp|svg|ico)$">
    Header set Cache-Control "max-age=2592000, public"
  </FilesMatch>
  <FilesMatch "\.(css|js)$">
    Header set Cache-Control "max-age=86400, public"
  </FilesMatch>
</IfModule>

# ── Tipos MIME corretos para fontes ──────────────────────────────────────────
<IfModule mod_mime.c>
  AddType font/woff2 .woff2
  AddType font/woff  .woff
</IfModule>
